SUPABASE_URL=your-supabase-url-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here
# Required on the server (Vercel, etc.): must be the service_role key (Project Settings → API),
# NOT the anon key. Used for: profile upserts, welcome + tutorial onboarding emails (prefs +
# idempotency), Auth admin getUserById, webhooks, admin tools. Missing or wrong key → skipped
# onboarding emails and weak diagnostics. See docs/EMAIL_SETUP.md.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# Stripe (Buy-Now + future escrow/Connect)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...


# ABN Lookup (Australian Business Register) - required when Admin Global Settings ABN validation is on
# Register at https://abr.business.gov.au/Tools/WebServices to get your GUID
ABR_GUID=

# Email (Resend) — required for welcome + tutorial (and other transactional) sends. See docs/EMAIL_SETUP.md
RESEND_API_KEY=re_...
# Production: verify bondback.io in Resend (Domains), then use e.g.:
RESEND_FROM=Bond Back <noreply@bondback.io>
# Local dev before domain verification (Resend sandbox sender):
# RESEND_FROM=Bond Back <onboarding@resend.dev>
# Optional Reply-To for all app emails
# RESEND_REPLY_TO=support@bondback.io

# Public origin — canonical production: https://www.bondback.io (set in Vercel for Production)
# Local dev:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (Vercel → Environment Variables):
# NEXT_PUBLIC_APP_URL=https://www.bondback.io
# Optional: only if metadata/sitemap base must differ from NEXT_PUBLIC_APP_URL
# NEXT_PUBLIC_SITE_URL=https://www.bondback.io

# Vercel: optional secret so /api/cron/* only runs when Authorization: Bearer matches.
# Set the same value in Vercel → Environment Variables; vercel.json cron will send this header.
# CRON_SECRET=
