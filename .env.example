SUPABASE_URL=your-supabase-url-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here
# Required on the server (Vercel, etc.): profile upserts from onboarding, notification emails
# (lookup recipient email via Auth Admin), webhooks, and admin tools. Without it, transactional
# emails to other users will not send. See docs/EMAIL_SETUP.md.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# Stripe (Buy-Now + future escrow/Connect)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...


# ABN Lookup (Australian Business Register) - required when Admin Global Settings ABN validation is on
# Register at https://abr.business.gov.au/Tools/WebServices to get your GUID
ABR_GUID=

# Email (Resend) - see docs/EMAIL_SETUP.md
RESEND_API_KEY=re_...
RESEND_FROM=Bond Back <onboarding@resend.dev>
# Optional Reply-To for all app emails
# RESEND_REPLY_TO=support@yourdomain.com
# Public origin of the app. Used for confirmation email links (signUp emailRedirectTo).
# On Vercel, set this to your production URL for Preview + Production so emails never point at
# a protected *.vercel.app preview (Vercel Deployment Protection / "Vercel login").
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel: optional secret so /api/cron/* only runs when Authorization: Bearer matches.
# Set the same value in Vercel → Environment Variables; vercel.json cron will send this header.
# CRON_SECRET=
