SUPABASE_URL=your-supabase-url-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here
# Required on the server (Vercel, etc.): must be the service_role key (Project Settings → API),
# NOT the anon key. Used for: profile upserts, welcome + tutorial onboarding emails (prefs +
# idempotency), Auth admin getUserById, webhooks, admin tools. Missing or wrong key → skipped
# onboarding emails and weak diagnostics. See docs/EMAIL_SETUP.md.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# Stripe (Buy-Now + future escrow/Connect)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...


# ABN Lookup (Australian Business Register) - required when Admin Global Settings ABN validation is on
# Register at https://abr.business.gov.au/Tools/WebServices to get your GUID
ABR_GUID=

# Email (Resend) — required for welcome + tutorial (and other transactional) sends. See docs/EMAIL_SETUP.md
RESEND_API_KEY=re_...
# From: if unset, code defaults to Bond Back <bondback2026@gmail.com> so support “Reply” works.
# Verify that sender in Resend (or use onboarding@resend.dev for sandbox only).
RESEND_FROM=Bond Back <bondback2026@gmail.com>
# After bondback.io is verified in Resend:
# RESEND_FROM=Bond Back <noreply@bondback.io>
# Local dev before any verified sender:
# RESEND_FROM=Bond Back <onboarding@resend.dev>
# Optional Reply-To for all app emails
# RESEND_REPLY_TO=bondback2026@gmail.com

# Inbox for admin notifications (new users, listings, disputes). Also used as the public
# “contact support” email in the UI when SUPPORT_CONTACT_EMAIL is unset.
# ADMIN_NOTIFICATION_EMAIL=you@yourdomain.com
# Optional override for support mailto / copy only (server-side emails, privacy text, etc.):
# SUPPORT_CONTACT_EMAIL=you@yourdomain.com
# Browser-only surfaces fall back to bondback2026@gmail.com unless you set:
# NEXT_PUBLIC_SUPPORT_CONTACT_EMAIL=you@yourdomain.com
# (Root layout passes ADMIN_NOTIFICATION_EMAIL into the app, so you usually only need the ADMIN_ var.)

# Public origin — canonical site is https://www.bondback.io (Supabase Auth redirect allowlist).
#
# Local dev only:
NEXT_PUBLIC_APP_URL=http://localhost:3000
#
# Vercel — set for Production AND Preview (same value stops *.vercel.app being used for OAuth/email):
#   NEXT_PUBLIC_APP_URL=https://www.bondback.io
# Optional if same as APP_URL:
#   NEXT_PUBLIC_SITE_URL=https://www.bondback.io
#
# Supabase Dashboard → Authentication → URL Configuration → Redirect URLs should include only:
#   https://www.bondback.io/**   and   http://localhost:3000/**
# Do not add https://*.vercel.app/** — preview deployments must use NEXT_PUBLIC_APP_URL above.
#
# (NEXT_PUBLIC_SUPABASE_URL must match your project — next/image allows that host for Storage URLs)

# Vercel: optional secret so /api/cron/* only runs when Authorization: Bearer matches.
# Set the same value in Vercel → Environment Variables; vercel.json cron will send this header.
# CRON_SECRET=
